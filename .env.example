# Pooled Neon Postgres connection string, used by the app at runtime
# (Prisma + @prisma/adapter-pg). Get it from your Neon project dashboard.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Direct/unpooled Neon connection string, used only by `prisma migrate`.
# If you don't have a separate one, it's fine to reuse DATABASE_URL here.
DIRECT_DATABASE_URL="postgresql://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"

# Where uploaded matricula PDFs are stored on disk, and the public URL prefix
# they're served from. Defaults to public/uploads/division-2 and
# /uploads/division-2 if unset — override for non-local storage.
# DIVISION_2_UPLOADS_DIR=
# DIVISION_2_UPLOADS_PUBLIC_PATH=
