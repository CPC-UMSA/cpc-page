# @juki-team packages are published to the public npm registry.
# Pinned here so a user-level ~/.npmrc pointing this scope at GitHub Packages
# (which requires auth even for public packages) does not take over.
@juki-team:registry=https://registry.npmjs.org/

# @juki-team/base-ui declares engines node >=24. Fail the install on an older
# runtime instead of installing and breaking later at runtime.
engine-strict=true
